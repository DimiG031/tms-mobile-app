{
  "expo": {
    "name": "TMS Mobile App",
    "slug": "tms-mobile-app",
    "scheme": "tmsmobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/b622376b-4950-4cc7-9d87-ff4bf586d9a8"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f2c4a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "rs.softechrs.tms",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TMS koristi lokaciju tokom aktivne ture kako bi dispecer video poziciju vozila.",
        "NSLocationWhenInUseUsageDescription": "TMS koristi lokaciju tokom aktivne ture za pracenje transporta.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "rs.softechrs.tms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f2c4a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TMS to track your location during active tours.",
          "locationAlwaysPermission": "Allow TMS to track your location in the background during active tours.",
          "locationWhenInUsePermission": "Allow TMS to access your location for tour tracking.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b622376b-4950-4cc7-9d87-ff4bf586d9a8"
      },
      "router": {}
    },
    "owner": "dimirs"
  }
}
